---
const people = [
  { id: 'nacho', name: 'Nacho', image: '/uploads/nacho.png', alt: 'Imagen del personaje Nacho' },
  { id: 'teti', name: 'Teti', image: '/uploads/teti.png', alt: 'Imagen del personaje Teti' },
  { id: 'naza', name: 'Naza', image: '/uploads/naza.png', alt: 'Imagen del personaje Naza' },
  { id: 'manu', name: 'Manu', image: '/uploads/manu.png', alt: 'Imagen del personaje Manu' },
  { id: 'luzzini', name: 'Luzzini', image: '/uploads/luzzini.png', alt: 'Imagen del personaje Luzzini' },
  { id: 'migue', name: 'Migue', image: '/uploads/migue.png', alt: 'Imagen del personaje Migue' },
  { id: 'mari', name: 'Mari', image: '/uploads/mari.png', alt: 'Imagen del personaje Mari' },
];

---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>HOLA</title>
    <meta name="description" content="Landing de personajes HOLA con cards seleccionables." />
  </head>
  <body>
    <main class="stage is-loading" aria-busy="true">
      <div class="loading-message" role="status">
        <img src="https://static.wikia.nocookie.net/kickbuttowski/images/a/a9/Bradley_Buttowski.webp/revision/latest?cb=20231025045829&path-prefix=es" alt="Brad Buttowski" />

      </div>
      <h1>HOLA</h1>

      <section class="cards" aria-label="Personajes">
        {people.map((person) => (
          <button class="person-card" type="button" data-person={person.id} aria-pressed="false">
            <span class="shine" aria-hidden="true"></span>
            <span class="portrait">
              <img src={person.image} alt={person.alt} loading="lazy" />
              <span class="group-name" aria-live="polite"></span>
            </span>
            <span class="person-name">{person.name}</span>
          </button>
        ))}
      </section>
    </main>

    <script>
      const STORAGE_KEY = 'esobrad-relaciones';
      const SHEET_ENDPOINT = 'https://script.google.com/macros/s/AKfycbxmw8Z5gN1Nz5ql5Mqq5tjE7Mpz-eCOiq0mCmnkQQaAFByHFAgIH7eTjMzJ2avR4MYrqQ/exec';
      const PEOPLE_ORDER = ['luzzini', 'manu', 'mari', 'migue', 'nacho', 'naza', 'teti'];
      const PERSON_ALIASES = {
        luzzni: 'luzzini',
      };
      let groups = {};
      let isReady = false;
      const selected = new Set();
      const stage = document.querySelector('.stage');
      const cards = Array.from(document.querySelectorAll('.person-card'));

      const getKey = () => Array.from(selected).sort().join('-');

      const normalizePerson = (value) => {
        const normalized = String(value ?? '').trim().toLowerCase();
        return PERSON_ALIASES[normalized] || normalized;
      };

      const rowsToGroups = (rows) => Object.fromEntries(
        rows
          .map((row) => {
            const key = row
              .slice(0, 7)
              .map(normalizePerson)
              .filter((person) => PEOPLE_ORDER.includes(person))
              .sort()
              .join('-');
            const name = String(row[8] ?? '').trim();
            return [key, name];
          })
          .filter(([key, name]) => key && name)
      );

      const normalizeGroupsResponse = (data) => {
        if (data?.groups && typeof data.groups === 'object') return data.groups;
        if (Array.isArray(data?.rows)) return rowsToGroups(data.rows);
        if (Array.isArray(data)) return rowsToGroups(data);
        if (data && typeof data === 'object') return data;
        return {};
      };

      const loadSheetGroups = async () => {
        if (!SHEET_ENDPOINT) return {};

        const response = await fetch(SHEET_ENDPOINT, { cache: 'no-store' });
        if (!response.ok) throw new Error('No se pudo cargar la planilla');
        return normalizeGroupsResponse(await response.json());
      };

      const loadGroups = async () => {
        const sheetGroups = await loadSheetGroups();
        localStorage.setItem(STORAGE_KEY, JSON.stringify(sheetGroups));
        return sheetGroups;
      };

      const updateCards = () => {
        const groupName = groups[getKey()] || '';

        cards.forEach((card) => {
          const isSelected = selected.has(card.dataset.person);
          const label = card.querySelector('.group-name');

          card.classList.toggle('is-selected', isSelected);
          card.setAttribute('aria-pressed', String(isSelected));
          label.textContent = isSelected ? groupName || 'Sin grupo definido' : '';
        });
      };

      cards.forEach((card) => {
        const image = card.querySelector('img');

        image.addEventListener('error', () => {
          image.classList.add('is-missing');
        });

          card.addEventListener('click', () => {
          if (!isReady) return;

          const person = card.dataset.person;

          if (selected.has(person)) selected.delete(person);
          else selected.add(person);

          updateCards();
        });
      });

      loadGroups()
        .then((loadedGroups) => {
          groups = loadedGroups;
          isReady = true;
          updateCards();
          stage.classList.remove('is-loading');
          stage.removeAttribute('aria-busy');
        })
        .catch((error) => {
          console.error(error);
          groups = {};
          isReady = true;
          updateCards();
          stage.classList.remove('is-loading');
          stage.removeAttribute('aria-busy');
        });
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: dark;
    --text: #eaf3ff;
    --blue: #2f8cff;
    --blue-soft: #83c7ff;
    --navy: #07111f;
    --ink: #03060b;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 18% 18%, rgba(47, 140, 255, 0.22), transparent 28rem),
      radial-gradient(circle at 82% 12%, rgba(131, 199, 255, 0.12), transparent 30rem),
      linear-gradient(135deg, #010308 0%, #07111f 48%, #000 100%);
    color: var(--text);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  body::before {
    position: fixed;
    inset: 0;
    pointer-events: none;
    content: "";
    background-image: linear-gradient(rgba(131, 199, 255, 0.07) 1px, transparent 1px), linear-gradient(90deg, rgba(47, 140, 255, 0.06) 1px, transparent 1px);
    background-size: 54px 54px;
    mask-image: radial-gradient(circle at center, black, transparent 78%);
  }

  .stage {
    position: relative;
    width: min(1420px, calc(100% - 32px));
    min-height: 100vh;
    margin: 0 auto;
    padding: clamp(42px, 8vw, 86px) 0;
  }

  .stage.is-loading > :not(.loading-message) {
    visibility: hidden;
  }

  .loading-message {
    position: absolute;
    inset: 50% auto auto 50%;
    display: grid;
    gap: 18px;
    place-items: center;
    margin: 0;
    color: var(--blue-soft);
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transform: translate(-50%, -50%);
  }

  .loading-message img {
    width: min(220px, 54vw);
    max-height: 300px;
    object-fit: contain;
    filter: drop-shadow(0 26px 42px rgba(47, 140, 255, 0.36));
    animation: brad-bounce 0.95s ease-in-out infinite alternate;
  }

  .loading-message span {
    white-space: nowrap;
  }

  @keyframes brad-bounce {
    from {
      transform: translateY(0) rotate(-2deg);
    }

    to {
      transform: translateY(-14px) rotate(2deg);
    }
  }

  .stage:not(.is-loading) .loading-message {
    display: none;
  }

  h1 {
    margin: 0 0 clamp(28px, 5vw, 54px);
    text-align: center;
    font-size: clamp(5.6rem, 18vw, 15rem);
    line-height: 0.78;
    letter-spacing: -0.12em;
    color: transparent;
    background: linear-gradient(90deg, #f3f8ff 0%, #83c7ff 42%, #2f8cff 100%);
    -webkit-background-clip: text;
    background-clip: text;
    filter: drop-shadow(0 28px 50px rgba(47, 140, 255, 0.26));
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(7, minmax(150px, 1fr));
    gap: clamp(14px, 1.7vw, 22px);
    align-items: stretch;
  }

  .person-card {
    position: relative;
    display: grid;
    gap: 15px;
    min-width: 0;
    padding: 12px 12px 16px;
    border: 1px solid rgba(131, 199, 255, 0.18);
    border-radius: 30px;
    overflow: hidden;
    background: linear-gradient(160deg, rgba(10, 28, 50, 0.9), rgba(3, 6, 11, 0.84));
    box-shadow: 0 26px 70px rgba(0, 0, 0, 0.42), inset 0 1px 0 rgba(131, 199, 255, 0.16);
    color: inherit;
    cursor: pointer;
    transform: translateY(0) rotate(var(--tilt, 0deg));
    transition: transform 220ms ease, border-color 220ms ease, box-shadow 220ms ease, background 220ms ease;
  }

  .person-card:nth-child(odd) {
    --tilt: -1.5deg;
  }

  .person-card:nth-child(even) {
    --tilt: 1.25deg;
  }

  .person-card:hover,
  .person-card:focus-visible {
    transform: translateY(-10px) rotate(0deg) scale(1.02);
    border-color: rgba(131, 199, 255, 0.54);
    box-shadow: 0 34px 90px rgba(0, 0, 0, 0.52), 0 0 42px rgba(47, 140, 255, 0.22);
    outline: none;
  }

  .person-card.is-selected {
    background: linear-gradient(160deg, rgba(47, 140, 255, 0.32), rgba(3, 6, 11, 0.92));
    border-color: rgba(131, 199, 255, 0.78);
    box-shadow: 0 34px 95px rgba(47, 140, 255, 0.24), inset 0 0 0 1px rgba(131, 199, 255, 0.24);
  }

  .shine {
    position: absolute;
    inset: -40% auto auto -35%;
    width: 120px;
    height: 180%;
    background: linear-gradient(90deg, transparent, rgba(131, 199, 255, 0.3), transparent);
    transform: rotate(24deg);
    transition: translate 300ms ease;
  }

  .person-card:hover .shine,
  .person-card:focus-visible .shine {
    translate: 230% 0;
  }

  .portrait {
    position: relative;
    display: grid;
    min-height: 390px;
    overflow: hidden;
    border-radius: 23px;
    background:
      radial-gradient(circle at 35% 22%, rgba(131, 199, 255, 0.44), transparent 18%),
      linear-gradient(145deg, rgba(12, 35, 62, 0.96), rgba(47, 140, 255, 0.58) 52%, rgba(1, 3, 8, 0.96));
  }

  .portrait img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center bottom;
  }

  .portrait img.is-missing {
    display: none;
  }

  .group-name {
    position: absolute;
    right: 10px;
    bottom: 10px;
    left: 10px;
    min-height: 0;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: transparent;
    font-size: 0;
    font-weight: 900;
    line-height: 1.05;
    text-wrap: balance;
    transition: all 180ms ease;
  }

  .person-card.is-selected .group-name {
    min-height: auto;
    padding: 10px 11px;
    border: 1px solid rgba(255, 255, 255, 0.4);
    background: rgba(3, 6, 11, 0.78);
    color: var(--text);
    font-size: 0.78rem;
    backdrop-filter: blur(14px);
  }

  .person-name {
    font-size: 1rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-align: center;
    text-transform: uppercase;
  }

  @media (max-width: 980px) {
    .cards {
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    }

    .portrait {
      min-height: 340px;
    }
  }

  @media (max-width: 620px) {
    .stage {
      width: min(100% - 22px, 420px);
      padding-top: 34px;
    }

    .cards {
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .portrait {
      min-height: 285px;
    }

    .person-card {
      border-radius: 24px;
      padding: 8px 8px 12px;
    }
  }
</style>
