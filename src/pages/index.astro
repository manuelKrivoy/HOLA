---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>HOLA</title>
    <meta name="description" content="Landing de personajes HOLA con cards seleccionables." />
  </head>
  <body>
    <main class="stage">
      <h1>HOLA</h1>

      <section class="cards" aria-label="Personajes">
        {people.map((person) => (
          <button class="person-card" type="button" data-person={person.id} aria-pressed="false">
            <span class="shine" aria-hidden="true"></span>
            <span class="portrait">
              <img src={person.image} alt={person.alt} loading="lazy" />
              <span class="initials" aria-hidden="true">{person.name.slice(0, 2)}</span>
              <span class="group-name" aria-live="polite"></span>
            </span>
            <span class="person-name">{person.name}</span>
          </button>
        ))}
      </section>
    </main>

    <script define:vars={{ groups }}>
      const selected = new Set();
      const cards = Array.from(document.querySelectorAll('.person-card'));

      const getKey = () => Array.from(selected).sort().join('-');

      const updateCards = () => {
        const groupName = groups[getKey()] || '';

        cards.forEach((card) => {
          const isSelected = selected.has(card.dataset.person);
          const label = card.querySelector('.group-name');

          card.classList.toggle('is-selected', isSelected);
          card.setAttribute('aria-pressed', String(isSelected));
          label.textContent = isSelected ? groupName || 'Sin grupo definido' : '';
        });
      };

      cards.forEach((card) => {
        const image = card.querySelector('img');

        image.addEventListener('error', () => {
          image.classList.add('is-missing');
        });

        card.addEventListener('click', () => {
          const person = card.dataset.person;

          if (selected.has(person)) selected.delete(person);
          else selected.add(person);

          updateCards();
        });
      });
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: dark;
    --cream: #fff7e7;
    --pink: #ff4f9a;
    --orange: #ff9d3d;
    --violet: #5c38ff;
    --ink: #11091d;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 18% 18%, rgba(255, 79, 154, 0.34), transparent 28rem),
      radial-gradient(circle at 82% 12%, rgba(255, 157, 61, 0.28), transparent 30rem),
      linear-gradient(135deg, #130722 0%, #241048 46%, #07020f 100%);
    color: var(--cream);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  body::before {
    position: fixed;
    inset: 0;
    pointer-events: none;
    content: "";
    background-image: linear-gradient(rgba(255, 255, 255, 0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 54px 54px;
    mask-image: radial-gradient(circle at center, black, transparent 78%);
  }

  .stage {
    position: relative;
    width: min(1180px, calc(100% - 32px));
    min-height: 100vh;
    margin: 0 auto;
    padding: clamp(42px, 8vw, 86px) 0;
  }

  h1 {
    margin: 0 0 clamp(28px, 5vw, 54px);
    text-align: center;
    font-size: clamp(5.6rem, 18vw, 15rem);
    line-height: 0.78;
    letter-spacing: -0.12em;
    color: transparent;
    background: linear-gradient(90deg, #fff9dc 0%, #ffca5f 28%, #ff4f9a 62%, #b9a4ff 100%);
    -webkit-background-clip: text;
    background-clip: text;
    filter: drop-shadow(0 28px 50px rgba(255, 79, 154, 0.22));
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(7, minmax(112px, 1fr));
    gap: clamp(14px, 2vw, 22px);
    align-items: stretch;
  }

  .person-card {
    position: relative;
    display: grid;
    gap: 13px;
    min-width: 0;
    padding: 10px 10px 15px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 30px;
    overflow: hidden;
    background: linear-gradient(160deg, rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0.055));
    box-shadow: 0 26px 70px rgba(0, 0, 0, 0.32), inset 0 1px 0 rgba(255, 255, 255, 0.25);
    color: inherit;
    cursor: pointer;
    transform: translateY(0) rotate(var(--tilt, 0deg));
    transition: transform 220ms ease, border-color 220ms ease, box-shadow 220ms ease, background 220ms ease;
  }

  .person-card:nth-child(odd) {
    --tilt: -1.5deg;
  }

  .person-card:nth-child(even) {
    --tilt: 1.25deg;
  }

  .person-card:hover,
  .person-card:focus-visible {
    transform: translateY(-10px) rotate(0deg) scale(1.02);
    border-color: rgba(255, 255, 255, 0.46);
    box-shadow: 0 34px 90px rgba(0, 0, 0, 0.42), 0 0 42px rgba(255, 79, 154, 0.18);
    outline: none;
  }

  .person-card.is-selected {
    background: linear-gradient(160deg, rgba(255, 209, 102, 0.33), rgba(255, 79, 154, 0.2));
    border-color: rgba(255, 247, 231, 0.72);
    box-shadow: 0 34px 95px rgba(255, 79, 154, 0.28), inset 0 0 0 1px rgba(255, 255, 255, 0.28);
  }

  .shine {
    position: absolute;
    inset: -40% auto auto -35%;
    width: 120px;
    height: 180%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.32), transparent);
    transform: rotate(24deg);
    transition: translate 300ms ease;
  }

  .person-card:hover .shine,
  .person-card:focus-visible .shine {
    translate: 230% 0;
  }

  .portrait {
    position: relative;
    display: grid;
    min-height: 245px;
    overflow: hidden;
    border-radius: 23px;
    background:
      radial-gradient(circle at 35% 22%, rgba(255, 255, 255, 0.56), transparent 18%),
      linear-gradient(145deg, rgba(255, 157, 61, 0.92), rgba(255, 79, 154, 0.86) 45%, rgba(92, 56, 255, 0.92));
  }

  .portrait img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .portrait img.is-missing {
    display: none;
  }

  .initials {
    place-self: center;
    font-size: clamp(2.8rem, 5vw, 4.7rem);
    font-weight: 950;
    letter-spacing: -0.12em;
    text-transform: uppercase;
    text-shadow: 0 14px 32px rgba(40, 4, 58, 0.38);
  }

  .group-name {
    position: absolute;
    right: 10px;
    bottom: 10px;
    left: 10px;
    min-height: 0;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: transparent;
    font-size: 0;
    font-weight: 900;
    line-height: 1.05;
    text-wrap: balance;
    transition: all 180ms ease;
  }

  .person-card.is-selected .group-name {
    min-height: auto;
    padding: 10px 11px;
    border: 1px solid rgba(255, 255, 255, 0.4);
    background: rgba(17, 9, 29, 0.72);
    color: var(--cream);
    font-size: 0.78rem;
    backdrop-filter: blur(14px);
  }

  .person-name {
    font-size: 1rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-align: center;
    text-transform: uppercase;
  }

  @media (max-width: 980px) {
    .cards {
      grid-template-columns: repeat(3, minmax(150px, 1fr));
    }
  }

  @media (max-width: 620px) {
    .stage {
      width: min(100% - 22px, 420px);
      padding-top: 34px;
    }

    .cards {
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .portrait {
      min-height: 205px;
    }

    .person-card {
      border-radius: 24px;
      padding: 8px 8px 12px;
    }
  }
</style>
