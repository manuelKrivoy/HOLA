---
const people = [
  { id: 'nacho', name: 'Nacho' },
  { id: 'teti', name: 'Teti' },
  { id: 'naza', name: 'Naza' },
  { id: 'manu', name: 'Manu' },
  { id: 'luzzini', name: 'Luzzini' },
  { id: 'migue', name: 'Migue' },
  { id: 'mari', name: 'Mari' },
];

const sheetUrl = 'https://docs.google.com/spreadsheets/d/13zG1njwgv2FaguvJdzry9pdqusQKXBkQdJs3Mh4cOuk/edit?gid=0#gid=0';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ESOBRAD</title>
    <meta name="description" content="Editor de relaciones HOLA conectado a Google Sheets." />
  </head>
  <body>
    <main class="shell is-loading" aria-busy="true">
      <div class="loading-message" role="status">
        <img src="https://static.wikia.nocookie.net/kickbuttowski/images/a/a9/Bradley_Buttowski.webp/revision/latest?cb=20231025045829&path-prefix=es" alt="Brad Buttowski" />
      </div>
      <header class="hero">
        <p class="eyebrow">Relaciones HOLA</p>
        <h1>ESOBRAD</h1>
        <p class="intro">Selecciona personas, escribe el nombre de la relación y confirma para guardarla en la planilla.</p>
        <a href={sheetUrl} class="sheet-link" target="_blank" rel="noreferrer">Abrir Google Sheets</a>
      </header>

      <section class="panel editor" aria-labelledby="visual-title">
        <div class="section-head">
          <div>
            <p class="eyebrow">Relación actual</p>
            <h2 id="visual-title">Editor visual</h2>
          </div>
          <p class="count"><span id="relation-count">0</span> relaciones</p>
        </div>

        <div class="people" aria-label="Personas">
          {people.map((person) => (
            <label class="person-option">
              <input type="checkbox" value={person.id} />
              <span>{person.name}</span>
            </label>
          ))}
        </div>

        <label class="field">
          <span>Nombre del grupo para la selección</span>
          <input id="group-name" type="text" placeholder="Ej: hola deportes" autocomplete="off" />
        </label>

        <div class="actions">
          <button id="confirm-relation" type="button">Confirmar relación</button>
        </div>

        <p id="selected-key" class="selected-key">Selecciona una o más personas.</p>
        <p id="status" class="status" role="status">Cargando relaciones...</p>
      </section>

      <section class="panel relations" aria-labelledby="relations-title">
        <div class="section-head">
          <div>
            <p class="eyebrow">Listado</p>
            <h2 id="relations-title">Relaciones guardadas</h2>
          </div>
        </div>
        <div id="relations-list" class="relations-list"></div>
      </section>
    </main>

    <script>
      const STORAGE_KEY = 'esobrad-relaciones';
      const SHEET_ENDPOINT = 'https://script.google.com/macros/s/AKfycbxmw8Z5gN1Nz5ql5Mqq5tjE7Mpz-eCOiq0mCmnkQQaAFByHFAgIH7eTjMzJ2avR4MYrqQ/exec';
      const PEOPLE_ORDER = ['luzzini', 'manu', 'mari', 'migue', 'nacho', 'naza', 'teti'];
      const PERSON_ALIASES = {
        luzzni: 'luzzini',
      };
      const peopleNames = {
        nacho: 'Nacho',
        teti: 'Teti',
        naza: 'Naza',
        manu: 'Manu',
        luzzini: 'Luzzini',
        migue: 'Migue',
        mari: 'Mari',
      };

      let groups = {};
      let isReady = false;

      const shell = document.querySelector('.shell');
      const checkboxes = Array.from(document.querySelectorAll('.person-option input'));
      const nameInput = document.querySelector('#group-name');
      const selectedKey = document.querySelector('#selected-key');
      const status = document.querySelector('#status');
      const relationCount = document.querySelector('#relation-count');
      const relationsList = document.querySelector('#relations-list');

      const normalizeKey = (ids) => ids.slice().sort().join('-');
      const getSelectedIds = () => checkboxes.filter((input) => input.checked).map((input) => input.value);
      const getCurrentKey = () => normalizeKey(getSelectedIds());
      const setStatus = (message) => {
        status.textContent = message;
      };

      const normalizePerson = (value) => {
        const normalized = String(value ?? '').trim().toLowerCase();
        return PERSON_ALIASES[normalized] || normalized;
      };

      const rowsToGroups = (rows) => Object.fromEntries(
        rows
          .map((row) => {
            const key = row
              .slice(0, 7)
              .map(normalizePerson)
              .filter((person) => PEOPLE_ORDER.includes(person))
              .sort()
              .join('-');
            const name = String(row[8] ?? '').trim();
            return [key, name];
          })
          .filter(([key, name]) => key && name)
      );

      const normalizeGroupsResponse = (data) => {
        if (data?.groups && typeof data.groups === 'object') return data.groups;
        if (Array.isArray(data?.rows)) return rowsToGroups(data.rows);
        if (Array.isArray(data)) return rowsToGroups(data);
        if (data && typeof data === 'object') return data;
        return {};
      };

      const setGroups = (nextGroups) => {
        groups = nextGroups;
        localStorage.setItem(STORAGE_KEY, JSON.stringify(groups));
        relationCount.textContent = Object.keys(groups).length;
        renderRelations();
        syncSelectionName();
      };

      const loadGroups = async () => {
        if (!SHEET_ENDPOINT) {
          localStorage.setItem(STORAGE_KEY, JSON.stringify({}));
          return {};
        }

        const response = await fetch(SHEET_ENDPOINT, { cache: 'no-store' });
        if (!response.ok) throw new Error('No se pudo cargar Google Sheets');
        return normalizeGroupsResponse(await response.json());
      };

      const syncSelectionName = () => {
        const key = getCurrentKey();
        nameInput.value = key ? groups[key] || '' : '';
        selectedKey.textContent = key ? `Clave: ${key}` : 'Selecciona una o más personas.';
      };

      const renderRelations = () => {
        const entries = Object.entries(groups).sort(([a], [b]) => a.localeCompare(b));
        relationsList.innerHTML = '';

        if (!entries.length) {
          relationsList.innerHTML = '<p class="empty">No hay relaciones guardadas.</p>';
          return;
        }

        entries.forEach(([key, value]) => {
          const button = document.createElement('button');
          const name = document.createElement('span');
          const detail = document.createElement('small');

          button.type = 'button';
          button.className = 'relation-row';
          name.textContent = value;
          detail.textContent = key.split('-').map((id) => peopleNames[id] || id).join(', ');
          button.append(name, detail);
          button.addEventListener('click', () => {
            const selected = new Set(key.split('-'));
            checkboxes.forEach((input) => {
              input.checked = selected.has(input.value);
            });
            nameInput.value = value;
            syncSelectionName();
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
          relationsList.append(button);
        });
      };

      checkboxes.forEach((input) => {
        input.addEventListener('change', () => {
          if (!isReady) return;
          syncSelectionName();
        });
      });

      document.querySelector('#confirm-relation').addEventListener('click', async () => {
        if (!isReady) return;

        const people = getSelectedIds();
        const key = normalizeKey(people);
        const name = nameInput.value.trim();

        if (!key || !name) {
          setStatus('Falta selección o nombre');
          return;
        }

        if (!SHEET_ENDPOINT) {
          setStatus('Falta configurar SHEET_ENDPOINT en el codigo');
          return;
        }

        setStatus('Guardando en Google Sheets...');

        try {
          const response = await fetch(SHEET_ENDPOINT, {
            method: 'POST',
            headers: { 'Content-Type': 'text/plain;charset=utf-8' },
            body: JSON.stringify({ action: 'upsert', people, name }),
          });
          if (!response.ok) throw new Error('Sheets no respondio correctamente');

          setGroups(normalizeGroupsResponse(await response.json()));
          setStatus('Relación confirmada');
        } catch (error) {
          setStatus(error.message);
        }
      });

      loadGroups()
        .then((loadedGroups) => {
          setGroups(loadedGroups);
          isReady = true;
          shell.classList.remove('is-loading');
          shell.removeAttribute('aria-busy');
          setStatus(SHEET_ENDPOINT ? 'Relaciones cargadas desde Google Sheets' : 'Configura SHEET_ENDPOINT para cargar relaciones');
        })
        .catch((error) => {
          setGroups({});
          isReady = true;
          shell.classList.remove('is-loading');
          shell.removeAttribute('aria-busy');
          setStatus(error.message);
        });
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: dark;
    --bg: #050812;
    --panel: rgba(10, 17, 31, 0.82);
    --panel-strong: rgba(17, 30, 54, 0.94);
    --line: rgba(131, 199, 255, 0.2);
    --text: #edf6ff;
    --muted: #9db5cc;
    --blue: #2f8cff;
    --cyan: #83c7ff;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background:
      radial-gradient(circle at 20% 0%, rgba(47, 140, 255, 0.28), transparent 30rem),
      radial-gradient(circle at 100% 10%, rgba(131, 199, 255, 0.16), transparent 34rem),
      var(--bg);
    color: var(--text);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  button,
  input {
    font: inherit;
  }

  .shell {
    width: min(1180px, calc(100% - 28px));
    margin: 0 auto;
    padding: clamp(28px, 6vw, 72px) 0;
  }

  .shell.is-loading > :not(.loading-message) {
    visibility: hidden;
  }

  .loading-message {
    position: fixed;
    inset: 50% auto auto 50%;
    display: grid;
    gap: 18px;
    place-items: center;
    margin: 0;
    color: var(--cyan);
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transform: translate(-50%, -50%);
  }

  .loading-message img {
    width: min(220px, 54vw);
    max-height: 300px;
    object-fit: contain;
    filter: drop-shadow(0 26px 42px rgba(47, 140, 255, 0.36));
    animation: brad-bounce 0.95s ease-in-out infinite alternate;
  }

  .loading-message span {
    white-space: nowrap;
  }

  @keyframes brad-bounce {
    from {
      transform: translateY(0) rotate(-2deg);
    }

    to {
      transform: translateY(-14px) rotate(2deg);
    }
  }

  .shell:not(.is-loading) .loading-message {
    display: none;
  }

  .hero {
    display: grid;
    gap: 12px;
    margin-bottom: 22px;
  }

  button,
  .sheet-link {
    width: fit-content;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: linear-gradient(135deg, var(--blue), #0f5ed1);
    color: white;
    padding: 11px 16px;
    cursor: pointer;
    text-decoration: none;
    box-shadow: 0 16px 42px rgba(47, 140, 255, 0.2);
  }

  h1,
  h2,
  p {
    margin: 0;
  }

  h1 {
    font-size: clamp(4.2rem, 14vw, 11rem);
    line-height: 0.82;
    letter-spacing: -0.12em;
    color: transparent;
    background: linear-gradient(90deg, white, var(--cyan), var(--blue));
    -webkit-background-clip: text;
    background-clip: text;
  }

  h2 {
    font-size: clamp(1.4rem, 3vw, 2rem);
  }

  .eyebrow {
    color: var(--cyan);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .intro {
    max-width: 720px;
    color: var(--muted);
  }

  .panel {
    margin-top: 18px;
    padding: clamp(18px, 3vw, 28px);
    border: 1px solid var(--line);
    border-radius: 28px;
    background: var(--panel);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.26);
    backdrop-filter: blur(18px);
  }

  .section-head {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    align-items: end;
    margin-bottom: 18px;
  }

  .count,
  .status,
  .selected-key {
    color: var(--muted);
  }

  .people {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 10px;
  }

  .person-option {
    display: grid;
    place-items: center;
    min-height: 58px;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.04);
    cursor: pointer;
  }

  .person-option:has(input:checked) {
    border-color: rgba(131, 199, 255, 0.72);
    background: rgba(47, 140, 255, 0.24);
  }

  .person-option input {
    position: absolute;
    opacity: 0;
  }

  .field {
    display: grid;
    gap: 8px;
    margin-top: 18px;
    color: var(--muted);
  }

  .field input {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: rgba(2, 6, 14, 0.72);
    color: var(--text);
    padding: 14px 16px;
    outline: none;
  }

  .actions {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-top: 16px;
  }

  .selected-key,
  .status {
    margin-top: 12px;
    word-break: break-word;
  }

  .relations-list {
    display: grid;
    gap: 10px;
  }

  .relation-row {
    display: grid;
    gap: 4px;
    width: 100%;
    border-radius: 18px;
    background: var(--panel-strong);
    text-align: left;
    box-shadow: none;
  }

  .relation-row small,
  .empty {
    color: var(--muted);
  }

  @media (max-width: 820px) {
    .section-head {
      display: grid;
    }

    .people {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .actions {
      align-items: stretch;
      flex-direction: column;
    }

    button,
    .sheet-link {
      justify-content: center;
      width: 100%;
      text-align: center;
    }
  }
</style>
